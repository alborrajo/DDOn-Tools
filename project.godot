; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DDOn Tools"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.5")
boot_splash/bg_color=Color(0.698039, 0.686275, 0.639216, 1)
boot_splash/image="res://splash.png"
config/icon="res://cyclops.png"
config/windows_native_icon="res://icon.ico"

[autoload]

DataProvider="*res://Providers/DataProvider.gd"
StorageProvider="*res://Providers/StorageProvider.tscn"
SetProvider="*res://Providers/SetProvider.tscn"
SelectedListManager="*res://Providers/SelectedListManager.tscn"
ServerProvider="*res://Providers/ServerProvider.tscn"

[gui]

theme/custom="uid://b1gv0wfdmojbx"
theme/custom_font="res://UI/font.tres"

